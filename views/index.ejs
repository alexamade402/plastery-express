<%- include("partials/head") %>
<%- include("partials/navbar") %>

<div class="container-fluid p-0 mb-5 wow fadeIn" data-wow-delay="0.1s">
    <div class="header-carousel owl-carousel">
        <div class="owl-carousel-item position-relative">
            <img class="img-fluid" src="/img/hero.jpg" alt="">
            <div class="owl-carousel-inner">
                <div class="container">
                    <div class="row justify-content-start">
                        <div class="col-lg-8">
                            <p class="text-primary text-uppercase fw-bold mb-2">Welcome to Plastery</p>
                            <h1 class="display-1 text-light mb-4 animated slideInDown">Professional Skin Care Solutions</h1>
                            <p class="text-light fs-5 mb-4 pb-3">Modern services and treatments with a professional and elegant presentation.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-xxl py-5">
    <div class="container">
        <div class="section-title text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">Our Services</p>
            <h1 class="display-6 mb-4">Explore Our Professional Services</h1>
        </div>

        <div class="row g-4">
            <% services.forEach(service => { %>
                <%- include("partials/service-card", { service: service }) %>
            <% }) %>
        </div>
    </div>
</div>

<%- include("partials/footer") %>